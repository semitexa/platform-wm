<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Semitexa Platform</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: system-ui, sans-serif; background: #1e1e2e; color: #cdd6f4; min-height: 100vh; }
        #wm-desktop { position: relative; width: 100vw; height: 100vh; overflow: hidden; }
        #wm-desktop-icons { position: absolute; top: 0; left: 0; right: 0; bottom: 52px; padding: 16px; display: flex; flex-wrap: wrap; align-content: flex-start; gap: 8px; z-index: 1; pointer-events: none; }
        #wm-desktop-icons > * { pointer-events: auto; }
        .wm-desktop-icon { width: 72px; padding: 8px; border-radius: 8px; background: transparent; border: none; cursor: pointer; color: #cdd6f4; font-size: 12px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 6px; transition: background .15s; }
        .wm-desktop-icon:hover { background: rgba(137, 180, 250, .2); }
        .wm-desktop-icon:active { background: rgba(137, 180, 250, .35); }
        .wm-desktop-icon__symbol { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 28px; line-height: 1; background: rgba(69, 71, 90, .8); border-radius: 10px; }
        .wm-desktop-icon__label { max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        #wm-windows { position: absolute; inset: 0; pointer-events: none; z-index: 10; }
        #wm-windows > * { pointer-events: auto; }
        #wm-app-bar { position: absolute; bottom: 0; left: 0; right: 0; padding: 8px; background: rgba(49,50,68,.9); display: flex; gap: 8px; flex-wrap: wrap; z-index: 1000; }
    </style>
</head>
<body>
    <div id="wm-desktop">
        <div id="wm-desktop-icons"></div>
        <div id="wm-windows"></div>
        <div id="wm-app-bar">
            <span style="font-size:12px;color:#a6adc8;align-self:center;margin-right:8px;">Apps:</span>
        </div>
    </div>
    <script>
        window.__WM_BOOTSTRAP__ = {{ wmBootstrap|json_encode|raw }};
    </script>
    <script src="/platform/static/wm-shell.js"></script>
</body>
</html>
